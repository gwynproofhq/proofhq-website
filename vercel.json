{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/platform", "destination": "/method", "permanent": true },
    { "source": "/playbooks", "destination": "/method", "permanent": true },
    { "source": "/how-it-works", "destination": "/", "permanent": true },
    { "source": "/before-after", "destination": "/", "permanent": true },
    { "source": "/system-flow", "destination": "/method", "permanent": true },
    { "source": "/walkthrough", "destination": "/method", "permanent": true },
    { "source": "/scorecard", "destination": "/method", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
